# ==============================================================================
# Digital Signage CMS — Production Environment Variables
# ==============================================================================
# Copy this file to `.env` and fill in the values.
# Never commit `.env` to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------------------
# PostgreSQL connection string (required)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/signage_cms?schema=public"

# ------------------------------------------------------------------------------
# AUTHENTICATION (NextAuth.js)
# ------------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-here"

# Base URL of your application (no trailing slash)
NEXTAUTH_URL="https://your-domain.com"

# ------------------------------------------------------------------------------
# FILE STORAGE
# ------------------------------------------------------------------------------
# Directory for uploaded media files (absolute path recommended)
UPLOAD_DIR="/app/uploads"

# Public URL prefix for accessing uploaded files
# Must match your reverse proxy / CDN configuration
NEXT_PUBLIC_UPLOAD_URL="/uploads"

# Maximum upload file size in bytes (default: 50MB)
MAX_UPLOAD_SIZE="52428800"

# ------------------------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------------------------
# Node environment
NODE_ENV="production"

# Port to listen on (default: 3000)
PORT="3000"
